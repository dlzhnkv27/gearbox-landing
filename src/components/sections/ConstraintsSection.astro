---
import ConstraintCard from "../ui/ConstraintCard.astro";
import SectionTitle from "../ui/SectionTitle.astro";

const { content } = Astro.props;
---

<section
  class="panel constraints-panel"
  id="app"
  data-motion-block
  data-motion-min-visible="100"
  data-motion-content="block-reveal"
>
  <img class="constraints-graphic" src={content.graphic} alt="" />

  <div class="constraints-copy">
    <SectionTitle title={content.title} subtitle={content.description} />
  </div>

  <div class="constraint-list">
    {content.cards.map((card) => (
      <ConstraintCard className={card.className} text={card.text} number={card.number} body={card.body} />
    ))}
  </div>
</section>
